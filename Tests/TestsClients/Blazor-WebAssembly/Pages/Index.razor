@page "/"
@using Xrpl.Client
@using System.Collections.Generic
@implements IAsyncDisposable

<h1>XRP Ledger Connection Test</h1>

<div style="margin: 20px 0;">
    <h3>Connection Status</h3>
    @if (IsConnected)
    {
        <p style="color: green; font-weight: bold;">✓ Connected to XRPL</p>
    }
    else
    {
        <p style="color: red; font-weight: bold;">✗ Not connected to XRPL</p>
    }
</div>

@if (ConnectionStatusMessages.Any())
{
    <div style="margin: 20px 0;">
        <h3>Connection Events</h3>
        <div style="background: #f5f5f5; padding: 10px; border-radius: 5px; max-height: 300px; overflow-y: auto;">
            @foreach (var message in ConnectionStatusMessages.OrderByDescending(m => m.Timestamp))
            {
                var color = message.Type switch
                {
                    MessageType.Success => "green",
                    MessageType.Warning => "#ff9800",
                    MessageType.Error => "red",
                    _ => "#666"
                };
                <div style="margin: 5px 0; padding: 5px; border-bottom: 1px solid #ddd;">
                    <small style="color: #666;">[@message.Timestamp.ToString("HH:mm:ss")]</small>
                    <span style="color: @color">@message.Message</span>
                </div>
            }
        </div>
    </div>
}

@code
{
    bool IsConnected { get; set; }
    List<StatusMessage> ConnectionStatusMessages { get; set; } = new List<StatusMessage>();
    
    [Inject]
    IXrplClient client { get; set; }

    public enum MessageType
    {
        Info,
        Success,
        Warning,
        Error
    }

    public class StatusMessage
    {
        public DateTime Timestamp { get; set; }
        public string Message { get; set; }
        public MessageType Type { get; set; } = MessageType.Info;
    }

    private OnConnected _onConnectedHandler;
    private OnDisconnect _onDisconnectHandler;
    private Action<string> _onConnectionStatusHandler;
    private OnError _onErrorHandler;
    private OnWarning _onWarningHandler;
    private OnWarning _onWarning2Handler;

    protected override async Task OnInitializedAsync()
    {
        _onConnectedHandler = async () =>
        {
            await InvokeAsync(() =>
            {
                IsConnected = true;
                AddStatusMessage("Connected to XRPL", MessageType.Success);
                Console.WriteLine("Connected to XRPL");
                StateHasChanged();
            });
        };

        _onDisconnectHandler = async (code, description) =>
        {
            await InvokeAsync(() =>
            {
                IsConnected = false;
                AddStatusMessage($"Disconnected: code={code}, {description}", MessageType.Warning);
                Console.WriteLine($"Disconnected from XRPL with code: {code}, description: {description}");
                StateHasChanged();
            });
        };

        _onConnectionStatusHandler = (statusMessage) =>
        {
            InvokeAsync(() =>
            {
                AddStatusMessage(statusMessage, MessageType.Info);
                Console.WriteLine($"Connection Status: {statusMessage}");
                StateHasChanged();
            });
        };

        _onErrorHandler = async (error, errorMessage, message, data) =>
        {
            await InvokeAsync(() =>
            {
                AddStatusMessage($"Error: {error} - {errorMessage}", MessageType.Error);
                Console.WriteLine($"Error: {error}, {errorMessage}, {message}");
                StateHasChanged();
            });
        };

        _onWarningHandler = async (warningType, warningMessage, message) =>
        {
            await InvokeAsync(() =>
            {
                AddStatusMessage($"Warning: {warningType} - {warningMessage}", MessageType.Warning);
                Console.WriteLine($"Warning: {warningType}, {warningMessage}, {message}");
                StateHasChanged();
            });
        };

        _onWarning2Handler = async (warningType, warningMessage, message) =>
        {
            await InvokeAsync(() =>
            {
                AddStatusMessage($"Warning2: {warningType} - {warningMessage}", MessageType.Warning);
                Console.WriteLine($"Warning2: {warningType}, {warningMessage}, {message}");
                StateHasChanged();
            });
        };

        client.connection.OnConnected += _onConnectedHandler;
        client.connection.OnDisconnect += _onDisconnectHandler;
        client.connection.OnConnectionStatus += _onConnectionStatusHandler;
        client.OnError += _onErrorHandler;
        client.OnWarning += _onWarningHandler;
        client.OnWarning2 += _onWarning2Handler;
        
        await base.OnInitializedAsync();
        
        await client.Connect();
        
        if (client.connection.IsConnected())
        {
            IsConnected = true;
            StateHasChanged();
        }
    }
    
    public async ValueTask DisposeAsync()
    {
        if (client != null)
        {
            if (_onConnectedHandler != null)
                client.connection.OnConnected -= _onConnectedHandler;
            
            if (_onDisconnectHandler != null)
                client.connection.OnDisconnect -= _onDisconnectHandler;
            
            if (_onConnectionStatusHandler != null)
                client.connection.OnConnectionStatus -= _onConnectionStatusHandler;
            
            if (_onErrorHandler != null)
                client.OnError -= _onErrorHandler;
            
            if (_onWarningHandler != null)
                client.OnWarning -= _onWarningHandler;
            
            if (_onWarning2Handler != null)
                client.OnWarning2 -= _onWarning2Handler;
        }
        
        await Task.CompletedTask;
    }
    
    private void AddStatusMessage(string message, MessageType type = MessageType.Info)
    {
        ConnectionStatusMessages.Add(new StatusMessage 
        { 
            Timestamp = DateTime.Now, 
            Message = message,
            Type = type
        });
        
        if (ConnectionStatusMessages.Count > 50)
        {
            ConnectionStatusMessages.RemoveAt(0);
        }
    }
}
