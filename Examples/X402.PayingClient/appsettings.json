{
  // x402 paying-client settings. Every value can be overridden by an environment variable
  // (e.g. PAYER_SEED).
  "X402": {
    // WebSocket URL of the rippled node used to autofill/sign the payment.
    "RippledWsUrl": "ws://localhost:6006",

    // Absolute URL of the payment-protected resource (the merchant's /paid endpoint).
    "ResourceUrl": "http://127.0.0.1:5402/paid",

    // REQUIRED. Seed of the funded payer wallet. Do NOT commit a real seed — set it via the
    // PAYER_SEED environment variable, or fill it in only in your local copy.
    "PayerSeed": "",

    // CAIP-2 network the client is willing to pay on.
    "Network": "xrpl:1",

    // Hard cap for XRP payments, in drops.
    "MaxAmountDrops": 10000000
  }
}
